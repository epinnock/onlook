{
    "extends": "@onlook/typescript/base.json",
    "compilerOptions": {
        "moduleResolution": "Bundler",
        "module": "ESNext",
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx"
    },
    "include": ["src/**/*", "fixtures/**/*", "scripts/**/*"],
    "exclude": ["node_modules"]
}

{
    "extends": "@onlook/typescript/base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "moduleResolution": "Bundler",
        "module": "ESNext",
        "target": "ES2022",
        "lib": ["ES2022"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}

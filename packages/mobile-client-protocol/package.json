        "typecheck": "tsc --noEmit",
        "test": "bun test"
    },
    "devDependencies": {
        "@onlook/eslint": "*",
        "@onlook/typescript": "*",
        "eslint": "^9.0.0",
        "typescript": "^5.5.4"
    },
    "dependencies": {

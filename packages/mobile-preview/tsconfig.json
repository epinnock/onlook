{
    "extends": "@onlook/typescript/base.json",
    "compilerOptions": {
        "moduleResolution": "Bundler",
        "module": "ESNext",
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "noEmit": true,
        "allowJs": false,
        "resolveJsonModule": true
    },
    "include": ["runtime/src/**/*"],
    "exclude": ["node_modules", "runtime/src/__tests__"]
}

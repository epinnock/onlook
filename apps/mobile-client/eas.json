{
    "cli": {
        "version": ">= 12.0.0",
        "appVersionSource": "remote",
        "requireCommit": false
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development",
            "ios": {
                "simulator": true,
                "image": "latest"
            },
            "android": {
                "buildType": "apk",
                "image": "latest",
                "gradleCommand": ":app:assembleDebug"
            },
            "env": {
                "EXPO_PUBLIC_ONLOOK_BUILD_PROFILE": "development"
            }
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "ios": {
                "simulator": true,
                "image": "latest"
            },
            "android": {
                "buildType": "apk",
                "image": "latest"
            },
            "env": {
                "EXPO_PUBLIC_ONLOOK_BUILD_PROFILE": "preview"
            }
        },
        "production": {
            "autoIncrement": true,
            "channel": "production",
            "ios": {
                "image": "latest",
                "resourceClass": "m-medium"
            },
            "android": {
                "buildType": "app-bundle",
                "image": "latest"
            },
            "env": {
                "EXPO_PUBLIC_ONLOOK_BUILD_PROFILE": "production"
            }
        }
    },
    "submit": {
        "preview": {
            "ios": {
                "appleId": "APPLE_ID_PLACEHOLDER",
                "ascAppId": "ASC_APP_ID_PLACEHOLDER",
                "appleTeamId": "APPLE_TEAM_ID_PLACEHOLDER"
            },
            "android": {
                "serviceAccountKeyPath": "./google-play-service-account.json",
                "track": "internal",
                "releaseStatus": "draft",
                "changesNotSentForReview": false
            }
        },
        "production": {
            "ios": {
                "appleId": "APPLE_ID_PLACEHOLDER",
                "ascAppId": "ASC_APP_ID_PLACEHOLDER",
                "appleTeamId": "APPLE_TEAM_ID_PLACEHOLDER"
            },
            "android": {
                "serviceAccountKeyPath": "./google-play-service-account.json",
                "track": "production",
                "releaseStatus": "draft",
                "changesNotSentForReview": false
            }
        }
    }
}
